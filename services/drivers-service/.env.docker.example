# Copiar a .env cuando ejecutes con Docker
# cp .env.docker.example .env

APP_NAME="Drivers Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=drivers-db
DB_PORT=3306
DB_DATABASE=drivers_db
DB_USERNAME=root
DB_PASSWORD=root

AUTH_SERVICE_URL=http://auth-service:8000

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis

# Después: php artisan key:generate && php artisan migrate --force
